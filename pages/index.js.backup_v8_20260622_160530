.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.op{background:var(--green);box-shadow:0 0 7px rgba(52,211,153,0.6);animation:blink 2.2s infinite;}
.wn{background:var(--amber);box-shadow:0 0 7px rgba(251,191,36,0.5);animation:blink 2.2s infinite;}
.er{background:var(--red);box-shadow:0 0 7px rgba(248,113,113,0.5);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.45}}
